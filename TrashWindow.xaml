<Window x:Class="PicDispatch.TrashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trash"
        Width="720"
        Height="520"
        MinWidth="640"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="12" ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource TitleBarBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Trash"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="18,0,0,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,6,8,6">
                <Button Content="Undo"
                        Command="{Binding UndoCommand}"
                        Style="{StaticResource TextButtonStyle}"
                        MinHeight="34"
                        Margin="0,0,6,0"/>
                <Button Content="Delete"
                        Command="{Binding RemoveCommand}"
                        Style="{StaticResource TextButtonStyle}"
                        Foreground="{StaticResource DangerBrush}"
                        MinHeight="34"
                        Margin="0,0,6,0"/>
                <Button Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource TextButtonStyle}"
                    MinHeight="34"
                    Margin="0,0,6,0"/>
                <Button Content="Clear Trash"
                        Command="{Binding ClearTrashCommand}"
                        Style="{StaticResource TextButtonStyle}"
                        Foreground="{StaticResource DangerBrush}"
                        MinHeight="34"
                        Margin="0,0,6,0"/>
                <Button Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="Close">
                    <Path Width="15"
                          Height="15"
                          Stretch="Uniform"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M18 6L6 18 M6 6l12 12"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Margin="18,14,18,12" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="8" Padding="12">
            <TextBlock Text="{Binding NotificationText}" TextWrapping="Wrap"/>
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasNotification}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <ListBox Grid.Row="2"
                 Margin="18,18,18,18"
                 ItemsSource="{Binding TrashItems}"
                 SelectedItem="{Binding SelectedTrashItem}"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding OriginalPath}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="44"
                                Height="44"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Background="{StaticResource PanelBackgroundBrush}"
                                CornerRadius="6"
                                ClipToBounds="True">
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="UniformToFill"
                                   SnapsToDevicePixels="True"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
    </Border>
</Window>
