<Window x:Class="PicDispatch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Width="840"
        Height="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Loaded="Window_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            CornerRadius="12"
                            GlassFrameThickness="1"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="12" ClipToBounds="True">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" DockPanel.Dock="Left"/>
            <Button Style="{StaticResource IconButtonStyle}" Click="Close_Click" HorizontalAlignment="Right" DockPanel.Dock="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Path Width="15" Height="15" Stretch="Uniform" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M18 6L6 18 M6 6l12 12"/>
            </Button>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Source folders" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButtonStyle}" Click="AddSource_Click" ToolTip="Add source folder">
                        <Path Width="18" Height="18" Stretch="Uniform" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M12 5v14 M5 12h14"/>
                    </Button>
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Padding="8">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Delete" Click="DeleteSourceMenu_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Target folders" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButtonStyle}" Click="AddTarget_Click" ToolTip="Add target folder">
                        <Path Width="18" Height="18" Stretch="Uniform" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M12 5v14 M5 12h14"/>
                    </Button>
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Padding="8">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Delete" Click="DeleteTargetMenu_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource ShortcutButtonStyle}"
                                        Tag="{Binding}"
                                        ToolTip="点击更改"
                                        Click="ShortcutButton_Click"
                                        Content="{Binding DisplayShortcut}"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding FolderPath}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
    </Border>
</Window>
